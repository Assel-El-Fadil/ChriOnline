<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.SpinnerValueFactory.IntegerSpinnerValueFactory?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Client.Controllers.ProductDetailsController"
            stylesheets="@admin_theme.css"
            styleClass="root"
            prefWidth="1100"
            prefHeight="750">

    <!-- ─── Top Header (same as catalog) ─── -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-header">
                <Label text="ChriOnline" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 30 60;">
                
                <!-- Back Button Row -->
                <HBox alignment="CENTER_LEFT">
                    <Button fx:id="btnBackCatalog"
                            text="← Back to Catalog"
                            styleClass="btn-secondary"
                            onAction="#handleBackToCatalog"/>
                </HBox>

                <VBox styleClass="content-section" spacing="32">
                    <padding>
                        <Insets top="32" right="40" bottom="32" left="40"/>
                    </padding>

                    <GridPane hgap="40" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="45" minWidth="300" hgrow="SOMETIMES"/>
                            <ColumnConstraints percentWidth="55" minWidth="350" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <!-- Left: Image Section -->
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="15" alignment="TOP_CENTER">
                            <StackPane styleClass="catalog-product-card" style="-fx-padding: 0; -fx-overflow: hidden;">
                                <VBox styleClass="catalog-card-image-bg" minHeight="380" alignment="CENTER">
                                    <ImageView fx:id="imgProduct" fitWidth="350" fitHeight="350"
                                             preserveRatio="true" smooth="true"/>
                                </VBox>
                            </StackPane>
                        </VBox>

                        <!-- Right: Info Section -->
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="20">
                            <VBox spacing="8">
                                <Label fx:id="lblCategory" text="CATEGORY"
                                       styleClass="catalog-card-badge, catalog-badge-new"
                                       style="-fx-font-size: 12px;"/>
                                <Label fx:id="lblName" text="Product Name" 
                                       styleClass="section-title" 
                                       style="-fx-font-size: 28px; -fx-padding: 0;"/>
                            </VBox>

                            <Label fx:id="lblDescription" text="Detailed product description goes here. It can span multiple lines to provide all necessary information to the customer."
                                   wrapText="true"
                                   styleClass="login-welcome-subtitle"
                                   style="-fx-font-size: 15px; -fx-line-spacing: 1.2;"/>

                            <HBox alignment="CENTER_LEFT" spacing="20">
                                <Label fx:id="lblPrice" text="0.00 MAD"
                                       styleClass="cart-total-value"
                                       style="-fx-font-size: 26px;"/>
                                <Label fx:id="lblStock" text="In Stock"
                                       styleClass="toolbar-label"
                                       style="-fx-font-size: 14px;"/>
                            </HBox>

                            <VBox spacing="12" style="-fx-padding: 10 0 0 0;">
                                <Label text="Quantity" styleClass="login-field-label"/>
                                <HBox spacing="16" alignment="CENTER_LEFT">
                                    <Spinner fx:id="quantitySpinner" editable="true" prefWidth="120"
                                             styleClass="combo-luxe"/>
                                    <Button fx:id="addToCartButton"
                                            text="Add to Cart"
                                            styleClass="btn-primary"
                                            onAction="#handleAddToCart"
                                            prefHeight="40"
                                            prefWidth="180"/>
                                </HBox>
                            </VBox>

                            <!-- Success/Error Message -->
                            <Label fx:id="cartStatusLabel" wrapText="true" 
                                   styleClass="cart-status-message"
                                   visible="false"/>
                        </VBox>
                    </GridPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
