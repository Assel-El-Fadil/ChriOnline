<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Client.Controllers.LoginController"
            stylesheets="@theme.css"
            styleClass="root"
            prefWidth="1100"
            prefHeight="750">

    <!-- ─── Top Header (same as catalog / cart) ─── -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-header">
                <Label text="ChriOnline" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </top>

    <!-- ─── Center: login form card ─── -->
    <center>
        <StackPane style="-fx-padding: 30 60;">
            <VBox styleClass="content-section" spacing="18" maxWidth="420">
                <padding>
                    <Insets top="28" right="32" bottom="28" left="32"/>
                </padding>

                <!-- Title -->
                <VBox spacing="4">
                    <Label text="Welcome Back" styleClass="section-title" style="-fx-padding: 0;"/>
                    <Label text="Sign in to continue shopping"
                           styleClass="login-welcome-subtitle"/>
                </VBox>

                <!-- Username field -->
                <VBox spacing="6">
                    <Label text="Username" styleClass="login-field-label"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               styleClass="login-form-field"/>
                </VBox>

                <!-- Password field with show/hide toggle -->
                <VBox spacing="6">
                    <Label text="Password" styleClass="login-field-label"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="passwordField"
                                           promptText="Enter your password"
                                           styleClass="login-form-field"/>
                            <TextField fx:id="passwordVisibleField"
                                       promptText="Enter your password"
                                       styleClass="login-form-field"
                                       visible="false"/>
                        </StackPane>
                        <Button fx:id="togglePasswordBtn"
                                text="Show"
                                onAction="#handleTogglePassword"
                                styleClass="toggle-password-btn"/>
                    </HBox>
                </VBox>

                <!-- Error label — hidden by default -->
                <Label fx:id="errorLabel"
                       styleClass="login-error-label"
                       visible="false"
                       wrapText="true"/>

                <!-- Buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Register"
                            onAction="#handleRegister"
                            styleClass="btn-secondary"/>
                    <Button fx:id="loginButton"
                            text="Login"
                            onAction="#handleLogin"
                            defaultButton="true"
                            styleClass="btn-primary"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
