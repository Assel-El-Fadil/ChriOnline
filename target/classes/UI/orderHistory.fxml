<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Client.Controllers.OrderHistoryController"
            stylesheets="@theme.css"
            styleClass="root"
            prefWidth="1100"
            prefHeight="750">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-header">
                <Label text="ChriOnline" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24;">
            <VBox styleClass="content-section" VBox.vgrow="ALWAYS" spacing="16">
                
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="My Orders" styleClass="section-title" style="-fx-padding: 0;"/>
                        <Label text="View your order history and track progress" styleClass="page-subtitle"/>
                    </VBox>
                    <Button text="← Back to Catalog"
                            styleClass="btn-secondary"
                            onAction="#handleBackToCatalog"/>
                </HBox>

                <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colRef"      text="Reference"  prefWidth="150"/>
                        <TableColumn fx:id="colDate"     text="Date"       prefWidth="200"/>
                        <TableColumn fx:id="colTotal"    text="Total"      prefWidth="120"/>
                        <TableColumn fx:id="colStatus"   text="Status"     prefWidth="150"/>
                        <TableColumn fx:id="colActions"  text="Actions"    prefWidth="180"/>
                        <TableColumn fx:id="colFacture"  text="Facture"    prefWidth="120"/>
                    </columns>
                </TableView>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label fx:id="statusLabel"
                           maxWidth="Infinity"
                           HBox.hgrow="ALWAYS"
                           wrapText="true"
                           styleClass="catalog-status"/>
                    <Button text="↻ Refresh"
                            onAction="#handleRefresh"
                            styleClass="btn-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
