<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="Client.Controllers.CatalogController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Top Area: Filters -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="categoryComboBox" promptText="Select Category" prefWidth="200" />
        <Button fx:id="showAllButton" text="Show All" onAction="#handleShowAll" />
        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh" />
    </HBox>

    <!-- Center Area: Data Table -->
    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName" text="Name" prefWidth="250" />
            <TableColumn fx:id="colCategory" text="Category" prefWidth="150" />
            <TableColumn fx:id="colPrice" text="Price" prefWidth="100" />
            <TableColumn fx:id="colStock" text="Stock" prefWidth="100" />
        </columns>
    </TableView>

    <!-- Bottom Area: Actions -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Label fx:id="statusLabel" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="viewDetailsButton" text="View Details" onAction="#handleViewDetails" disable="true" />
        <Button fx:id="addToCartButton" text="Add to Cart" onAction="#handleAddToCart" disable="true" />
    </HBox>

</VBox>
