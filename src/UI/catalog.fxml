<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Client.Controllers.CatalogController"
            stylesheets="@admin_theme.css"
            styleClass="root"
            prefWidth="1100"
            prefHeight="750">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-header">
                <Label text="ChriOnline" styleClass="logo-text"/>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField promptText="Search for any product or brand..."
                           styleClass="search-bar"
                           focusTraversable="false"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="My Orders"
                            styleClass="btn-secondary"
                            onAction="#handleOpenOrderHistory"
                            focusTraversable="false"/>
                    <Label text="📍" styleClass="icon-button"/>
                    <Button text="🛒"
                            styleClass="catalog-header-cart-btn"
                            onAction="#handleOpenCart"
                            focusTraversable="false"/>
                    <Label text="Cart"
                           styleClass="icon-button"
                           style="-fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Region prefWidth="8"/>
                    <Button text="👤 Profile"
                            styleClass="btn-secondary"
                            onAction="#handleOpenProfile"
                            focusTraversable="false"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24;">
            <VBox styleClass="content-section" VBox.vgrow="ALWAYS" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="All Products" styleClass="section-title" style="-fx-padding: 0;"/>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label fx:id="lblProductCount" text="0 products found"
                                   styleClass="page-subtitle"/>
                            <Label text="Browse and add items to your cart"
                                   styleClass="page-subtitle"/>
                        </HBox>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Category" styleClass="toolbar-label"/>
                    <ComboBox fx:id="categoryComboBox"
                              promptText="Select category"
                              prefWidth="240"
                              styleClass="combo-luxe"/>
                    <Button fx:id="showAllButton"
                            text="Show All"
                            onAction="#handleShowAll"
                            styleClass="btn-primary"/>
                    <Button fx:id="refreshButton"
                            text="↻ Refresh"
                            onAction="#handleRefresh"
                            styleClass="btn-secondary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <ScrollPane fx:id="productScroll"
                            fitToWidth="true"
                            hbarPolicy="NEVER"
                            styleClass="catalog-scroll"
                            VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="productGrid"
                              hgap="20"
                              vgap="20"
                              styleClass="catalog-flow">
                        <padding>
                            <Insets top="4" right="8" bottom="16" left="8"/>
                        </padding>
                    </FlowPane>
                </ScrollPane>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label fx:id="statusLabel"
                           maxWidth="Infinity"
                           HBox.hgrow="ALWAYS"
                           wrapText="true"
                           styleClass="catalog-status"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
