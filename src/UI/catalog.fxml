<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Client.Controllers.CatalogController"
            stylesheets="@admin_theme.css"
            styleClass="root"
            prefWidth="1100"
            prefHeight="750">

    <!-- LuxeStore-style top bar (matches admin.fxml) -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-header">
                <Label text="LuxeStore" styleClass="logo-text"/>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField promptText="Search for any product or brand..."
                           styleClass="search-bar"
                           focusTraversable="false"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Label text="📍" styleClass="icon-button"/>
                    <Label text="🛒" styleClass="icon-button"/>
                    <Label text="👤 Shop"
                           styleClass="icon-button"
                           style="-fx-font-weight: bold; -fx-text-fill: #111827;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24;">
            <VBox styleClass="content-section" VBox.vgrow="ALWAYS" spacing="15">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="All Products" styleClass="section-title" style="-fx-padding: 0;"/>
                        <Label text="Browse the catalog and add items to your cart"
                               styleClass="page-subtitle"/>
                    </VBox>
                </HBox>

                <!-- Toolbar: category filter -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Category" styleClass="toolbar-label"/>
                    <ComboBox fx:id="categoryComboBox"
                              promptText="Select category"
                              prefWidth="240"
                              styleClass="combo-luxe"/>
                    <Button fx:id="showAllButton"
                            text="Show All"
                            onAction="#handleShowAll"
                            styleClass="btn-primary"/>
                    <Button fx:id="refreshButton"
                            text="↻ Refresh"
                            onAction="#handleRefresh"
                            styleClass="btn-secondary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <TableView fx:id="productTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colName" text="Product Name" prefWidth="280"/>
                        <TableColumn fx:id="colCategory" text="Category" prefWidth="200"/>
                        <TableColumn fx:id="colPrice" text="Price" prefWidth="140"/>
                        <TableColumn fx:id="colStock" text="Stock" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Label fx:id="statusLabel"
                           maxWidth="Infinity"
                           HBox.hgrow="ALWAYS"
                           wrapText="true"
                           styleClass="catalog-status"/>
                    <Button fx:id="viewDetailsButton"
                            text="View Details"
                            onAction="#handleViewDetails"
                            disable="true"
                            styleClass="btn-secondary"/>
                    <Button fx:id="addToCartButton"
                            text="Add to Cart"
                            onAction="#handleAddToCart"
                            disable="true"
                            styleClass="btn-primary"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
