<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Client.Controllers.CheckoutController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Title -->
    <Label text="Checkout"
           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <!-- ── Order Summary section ────────────────────────────────── -->
    <Label text="Order Summary"
           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

    <TableView fx:id="summaryTable" prefHeight="160">
        <columns>
            <TableColumn fx:id="colName"      text="Product"    prefWidth="200"/>
            <TableColumn fx:id="colQty"       text="Qty"        prefWidth="55"/>
            <TableColumn fx:id="colUnitPrice" text="Unit Price" prefWidth="100"/>
            <TableColumn fx:id="colSubtotal"  text="Subtotal"   prefWidth="100"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="8">
        <Label text="Total:" style="-fx-font-weight: bold;"/>
        <Label fx:id="totalLabel" text="0.00 MAD"
               style="-fx-font-weight: bold; -fx-text-fill: #2a7ae2;"/>
    </HBox>

    <Separator/>

    <!-- ── Payment section ──────────────────────────────────────── -->
    <Label text="Payment Details"
           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

    <GridPane hgap="12" vgap="10">
        <padding><Insets top="4"/></padding>

        <!-- Card Number -->
        <Label text="Card Number" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="cardNumberField"
                   promptText="16 digits"
                   prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <!-- Card Holder -->
        <Label text="Card Holder" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="cardHolderField"
                   promptText="Full name on card"
                   prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <!-- Expiry + CVV on same row -->
        <Label text="Expiry (MM/YY)" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <TextField fx:id="expiryField"
                       promptText="MM/YY"
                       prefWidth="90"/>
            <Label text="CVV" style="-fx-padding: 0 0 0 10;"/>
            <TextField fx:id="cvvField"
                       promptText="3 digits"
                       prefWidth="70"/>
        </HBox>
    </GridPane>

    <!-- Error label — hidden by default -->
    <Label fx:id="errorLabel"
           style="-fx-text-fill: red; -fx-font-size: 12px;"
           visible="false"
           wrapText="true"/>

    <!-- Place Order button -->
    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="placeOrderButton"
                text="Place Order"
                onAction="#handlePlaceOrder"
                defaultButton="true"
                style="-fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px;"/>
    </HBox>

</VBox>
