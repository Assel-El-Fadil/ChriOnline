<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Client.Controllers.OrderStatusProgressController"
            stylesheets="@theme.css"
            styleClass="root"
            prefWidth="1100"
            prefHeight="750">

    <!-- ─── Top Header ─── -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-header">
                <Label text="ChriOnline" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 30 60;">

                <!-- Back Button -->
                <HBox alignment="CENTER_LEFT">
                    <Button text="← Back to Order History"
                            styleClass="btn-secondary"
                            onAction="#handleBack"/>
                </HBox>

                <VBox styleClass="content-section" spacing="30">
                    <padding>
                        <Insets top="40" right="50" bottom="40" left="50"/>
                    </padding>

                    <!-- Order Info Header -->
                    <VBox spacing="8">
                        <Label fx:id="lblOrderRef" text="Order #REF-12345" styleClass="section-title" style="-fx-padding: 0;"/>
                        <Label fx:id="lblOrderDate" text="Placed on March 26, 2026" styleClass="login-welcome-subtitle"/>
                    </VBox>

                    <!-- Progress Visualizer -->
                    <VBox spacing="20" alignment="CENTER">
                        <HBox alignment="CENTER" spacing="0">
                            <!-- PENDING -->
                            <VBox alignment="CENTER" spacing="10">
                                <StackPane>
                                    <Circle fx:id="step1Circle" radius="15" fill="#3B82F6" stroke="#3B82F6"/>
                                    <Label text="1" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                                </StackPane>
                                <Label text="Pending" styleClass="toolbar-label"/>
                            </VBox>

                            <Line fx:id="line1" startX="0" endX="100" stroke="#E5E7EB" strokeWidth="4"/>

                            <!-- VALIDATED -->
                            <VBox alignment="CENTER" spacing="10">
                                <StackPane>
                                    <Circle fx:id="step2Circle" radius="15" fill="white" stroke="#E5E7EB"/>
                                    <Label text="2" style="-fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                                </StackPane>
                                <Label text="Validated" styleClass="toolbar-label"/>
                            </VBox>

                            <Line fx:id="line2" startX="0" endX="100" stroke="#E5E7EB" strokeWidth="4"/>

                            <!-- SHIPPED -->
                            <VBox alignment="CENTER" spacing="10">
                                <StackPane>
                                    <Circle fx:id="step3Circle" radius="15" fill="white" stroke="#E5E7EB"/>
                                    <Label text="3" style="-fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                                </StackPane>
                                <Label text="Shipped" styleClass="toolbar-label"/>
                            </VBox>

                            <Line fx:id="line3" startX="0" endX="100" stroke="#E5E7EB" strokeWidth="4"/>

                            <!-- DELIVERED -->
                            <VBox alignment="CENTER" spacing="10">
                                <StackPane>
                                    <Circle fx:id="step4Circle" radius="15" fill="white" stroke="#E5E7EB"/>
                                    <Label text="4" style="-fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                                </StackPane>
                                <Label text="Delivered" styleClass="toolbar-label"/>
                            </VBox>
                        </HBox>

                        <!-- Status Badge for Cancelled -->
                        <Label fx:id="lblCancelledStatus" text="ORDER CANCELLED"
                               styleClass="catalog-card-badge, catalog-badge-sale"
                               visible="false" managed="false"
                               style="-fx-font-size: 16px; -fx-padding: 10 20;"/>
                    </VBox>

                    <Region prefHeight="20"/>

                    <!-- Details Section -->
                    <VBox spacing="15">
                        <Label text="Status Details" styleClass="login-field-label"/>
                        <VBox spacing="10" style="-fx-background-color: #F9FAFB; -fx-padding: 20; -fx-background-radius: 8;">
                            <HBox spacing="10">
                                <Label text="Current Status:" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblStatusText" text="Your order is being processed."/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Total Amount:" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblTotalAmount" text="0.00 MAD"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Refresh Status"
                                styleClass="btn-primary"
                                onAction="#handleRefresh"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
