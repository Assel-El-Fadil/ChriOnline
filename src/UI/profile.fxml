<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Client.Controllers.ProfileController"
            stylesheets="@admin_theme.css"
            styleClass="root"
            prefWidth="1100"
            prefHeight="750">

    <!-- ── Header ── -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-header">
                <Label text="ChriOnline" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="← Back to Catalog" onAction="#handleBack"
                            styleClass="btn-secondary" focusTraversable="false"/>
                    <Button text="Logout" onAction="#handleLogout"
                            styleClass="btn-danger" focusTraversable="false"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- ── Main Content ── -->
    <center>
        <VBox spacing="20" style="-fx-padding: 40 80;" alignment="TOP_CENTER">

            <!-- Profile Card -->
            <VBox styleClass="content-section" spacing="24" maxWidth="700">

                <!-- Section Header -->
                <HBox alignment="CENTER_LEFT">
                    <Label text="My Profile" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel"
                           style="-fx-font-weight: bold;"
                           visible="false"/>
                </HBox>

                <!-- Avatar + Name Row -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox alignment="CENTER" spacing="8">
                        <StackPane>
                            <Label fx:id="avatarLabel"
                                   style="-fx-font-size: 48px; -fx-background-color: #EFF6FF;
                                          -fx-background-radius: 40; -fx-padding: 20;
                                          -fx-text-fill: #3B82F6; -fx-font-weight: bold;
                                          -fx-min-width: 80; -fx-min-height: 80;
                                          -fx-alignment: center;"/>
                            <ImageView fx:id="avatarImageView"
                                       fitWidth="80" fitHeight="80">
                                <clip>
                                    <Circle radius="40" centerX="40" centerY="40"/>
                                </clip>
                            </ImageView>
                        </StackPane>
                        <Button text="Change Photo" onAction="#handleChangePhoto"
                                styleClass="btn-secondary"
                                style="-fx-font-size: 11px; -fx-padding: 4 8;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label fx:id="fullNameLabel"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label fx:id="roleLabel"
                               style="-fx-font-size: 14px; -fx-text-fill: #6B7280;"/>
                    </VBox>
                </HBox>

                <!-- Editable Fields -->
                <VBox spacing="16">

                    <HBox spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="First Name" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="firstNameField" styleClass="search-bar"
                                       style="-fx-pref-width: 999;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Last Name" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="lastNameField" styleClass="search-bar"
                                       style="-fx-pref-width: 999;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4">
                        <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="usernameField" styleClass="search-bar"
                                   editable="false" style="-fx-opacity: 0.6;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="emailField" styleClass="search-bar"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Address" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="addressField" styleClass="search-bar" promptText="Not set"/>
                    </VBox>

                </VBox>

                <!-- Action Buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button fx:id="saveButton" text="Save Changes" styleClass="btn-primary"
                            onAction="#handleSave"
                            style="-fx-background-color: #10B981;"/>
                </HBox>

            </VBox>
        </VBox>
    </center>
</BorderPane>
