<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      prefWidth="380" prefHeight="320"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Client.Controllers.RegisterController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Title -->
    <Label text="ChriOnline — Register"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Username field -->
    <VBox spacing="4">
        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="Enter username"/>
    </VBox>

    <!-- Password field -->
    <VBox spacing="4">
        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="At least 6 characters"/>
    </VBox>

    <!-- Email field -->
    <VBox spacing="4">
        <Label text="Email"/>
        <TextField fx:id="emailField" promptText="example@email.com"/>
    </VBox>

    <!-- Error label — hidden by default -->
    <Label fx:id="errorLabel"
           style="-fx-text-fill: red; -fx-font-size: 12px;"
           visible="false"
           wrapText="true"/>

    <!-- Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Back to Login" onAction="#handleBackToLogin"
                style="-fx-cursor: hand;"/>
        <Button fx:id="registerButton" text="Register" onAction="#handleRegister"
                defaultButton="true"
                style="-fx-cursor: hand; -fx-font-weight: bold;"/>
    </HBox>

</VBox>
