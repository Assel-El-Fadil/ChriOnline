<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.SpinnerValueFactory.IntegerSpinnerValueFactory?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      stylesheets="@admin_theme.css"
      spacing="20"
      styleClass="root"
      prefWidth="900"
      prefHeight="640">

    <padding>
        <Insets top="0" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Top: back button, left -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Button fx:id="btnBackCatalog"
                text="← Back to Catalog"
                styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Center: product card -->
    <VBox VBox.vgrow="ALWAYS" styleClass="content-section" spacing="16">
        <GridPane hgap="28" vgap="12" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints percentWidth="42" minWidth="220" hgrow="SOMETIMES"/>
                <ColumnConstraints percentWidth="58" minWidth="280" hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Left: placeholder (rectangle behind optional ImageView) -->
            <StackPane GridPane.columnIndex="0" GridPane.rowIndex="0"
                       minHeight="280" prefHeight="320" maxHeight="420">
                <Rectangle width="320" height="320" arcWidth="14" arcHeight="14"
                           fill="#E5E7EB"
                           stroke="#D1D5DB" strokeWidth="1"/>
                <ImageView fx:id="imgProduct" fitWidth="300" fitHeight="300"
                         preserveRatio="true" smooth="true"/>
            </StackPane>

            <!-- Right: details -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="12" fillWidth="true">
                <Label fx:id="lblProductName" text="Product name" styleClass="section-title"
                       wrapText="true"/>
                <Label fx:id="lblProductCategory" text="Category"
                       style="-fx-text-fill: #6B7280; -fx-font-size: 14px;" wrapText="true"/>
                <Label fx:id="lblProductDescription" text="Description"
                       wrapText="true"
                       style="-fx-text-fill: #374151; -fx-font-size: 14px;"/>
                <Label fx:id="lblProductPrice" text="0.00 MAD"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label fx:id="lblProductStock" text="Stock: —"
                       style="-fx-font-size: 14px; -fx-text-fill: #374151;"/>
            </VBox>
        </GridPane>
    </VBox>

    <!-- Bottom: quantity + add -->
    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
        <Label text="Quantity:" style="-fx-font-weight: 600; -fx-text-fill: #374151;"/>
        <Spinner fx:id="spinnerQuantity" editable="true" prefWidth="120">
            <valueFactory>
                <IntegerSpinnerValueFactory min="1" max="9999" initialValue="1"/>
            </valueFactory>
        </Spinner>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAddToCart"
                text="Add to Cart"
                styleClass="btn-primary"/>
    </HBox>
</VBox>
